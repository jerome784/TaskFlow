# Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/taskflow
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_secure_database_password_here

# JWT Configuration
# Note: For production, generate a secure random 256-bit (32 byte) key and encode it in Hex or Base64.
# Example generated via: openssl rand -hex 32
JWT_SECRET=your_secure_random_jwt_secret_key_here
JWT_EXPIRATION=86400000

# File Upload Configuration
FILE_UPLOAD_DIR=/app/uploads
